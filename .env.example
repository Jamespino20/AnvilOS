# Prisma connection string (MySQL)
# Pool params: connectionLimit=max conns, idleTimeout=seconds before release, acquireTimeout=seconds to wait
# Hostinger limit: max_connections_per_hour=500. Keep connectionLimit low (3-5) to stay under.
DATABASE_URL="mysql://user:password@localhost:3306/anvilos?connectionLimit=3&idleTimeout=120&acquireTimeout=10"

# Auth
AUTH_SECRET="" #> openssl rand -base64 32
AUTH_TRUST_HOST=true
AUTH_URL="http://localhost:3000"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS="" # Google's App Passwords
SMTP_FROM=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NODE_TLS_REJECT_UNAUTHORIZED="0"; # NEVER use in production — only for local dev with self-signed certs