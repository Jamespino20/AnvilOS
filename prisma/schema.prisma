generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ────────────────────────────────────────────────────────────────────
// Enums (native PostgreSQL enums)
// ────────────────────────────────────────────────────────────────────

enum TransactionType {
  SaleWalkIn
  SalePO
  Restock
  Adjustment
  Return
  Damage

  @@map("transaction_type")
}

enum DeliveryMethod {
  Pickup
  Delivery
  COD
  WalkIn

  @@map("delivery_method")
}

enum TransactionStatus {
  Ongoing
  Processing
  OnTheWay
  Completed
  Cancelled

  @@map("transaction_status")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  STAFF

  @@map("user_role")
}

enum EmailTokenPurpose {
  EmailVerification
  PasswordReset

  @@map("email_token_purpose")
}

// ────────────────────────────────────────────────────────────────────
// Models
// ────────────────────────────────────────────────────────────────────

/// System users / cashiers / admins
model User {
  id                Int      @id @default(autoincrement()) @map("SELLER_ID")
  sellerName        String   @unique @map("SELLER_NAME")
  username          String   @unique @map("USERNAME")
  passwordHash      String   @map("PASSWORD_HASH")
  oldPasswordHash   String?  @map("OLD_PASSWORD_HASH")
  email             String?  @map("EMAIL")
  imageUrl          String?  @db.LongText @map("IMAGE_URL")
  role              UserRole @default(ADMIN) @map("ROLE")
  emailVerified     DateTime? @map("EMAIL_VERIFIED")
  totpSecret        String?  @map("TOTP_SECRET")
  totpEnabled       Boolean  @default(false) @map("TOTP_ENABLED")
  registryDate      DateTime @map("REGISTRY_DATE")
  lastLogin         DateTime @default(now()) @map("LAST_LOGIN")
  isActive          Boolean  @default(true) @map("IS_ACTIVE")
  notifLowStock         Boolean @default(true) @map("NOTIF_LOW_STOCK")
  notifDailySales       Boolean @default(true) @map("NOTIF_DAILY_SALES")
  notifTransaction      Boolean @default(true) @map("NOTIF_TRANSACTION")

  transactions        Transaction[]
  buyers              Buyer[]
  auditLogs           AuditLog[]
  emailTokens         EmailToken[]
  notificationReads   NotificationRead[]
  customDownloadables CustomDownloadable[]

  @@map("users")
}

model EmailToken {
  id        Int               @id @default(autoincrement()) @map("TOKEN_ID")
  userId    Int               @map("SELLER_ID")
  purpose   EmailTokenPurpose @map("PURPOSE")
  tokenHash String            @map("TOKEN_HASH")
  codeHash  String            @map("CODE_HASH")
  expiresAt DateTime          @map("EXPIRES_AT")
  usedAt    DateTime?         @map("USED_AT")
  createdAt DateTime          @default(now()) @map("CREATED_AT")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
  @@map("email_tokens")
}

/// Product categories (supports one level of subcategories)
model Category {
  id              Int       @id @default(autoincrement()) @map("CATEGORY_ID")
  name            String    @map("CATEGORY")
  parentCategoryId Int?     @map("PARENT_CATEGORY_ID")
  isAvailable     Boolean   @default(true) @map("IS_AVAILABLE")
  createdAt       DateTime? @map("CREATED_AT")
  updatedAt       DateTime  @default(now()) @updatedAt @map("UPDATED_AT")

  parent   Category?  @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@unique([name, parentCategoryId])
  @@map("categories")
}

/// Vendors / suppliers
model Supplier {
  id            Int     @id @default(autoincrement()) @map("SUPPLIER_ID")
  supplierName  String  @map("SUPPLIER_NAME")
  contactName   String? @map("CONTACT_NAME")
  contactNumber String? @map("CONTACT_NUMBER")
  email         String? @map("EMAIL")
  address       String? @map("ADDRESS")
  tin           String? @map("TIN")
  isAvailable   Boolean @default(true) @map("IS_AVAILABLE")

  products Product[]

  @@map("suppliers")
}

/// Product brands
model Brand {
  id          Int       @id @default(autoincrement()) @map("BRAND_ID")
  name        String    @map("BRAND_NAME")
  isAvailable Boolean   @default(true) @map("IS_AVAILABLE")
  createdAt   DateTime? @map("CREATED_AT")
  updatedAt   DateTime  @default(now()) @updatedAt @map("UPDATED_AT")

  products Product[]

  @@unique([name])
  @@map("brands")
}

/// Inventory items / stock keeping units
model Product {
  id             Int      @id @default(autoincrement()) @map("PRODUCT_ID")
  productName    String   @map("PRODUCT_NAME")
  categoryId     Int?     @map("CATEGORY_ID")
  category       String   @map("CATEGORY")
  supplierId     Int?     @map("SUPPLIER_ID")
  supplierName   String   @map("SUPPLIER_NAME")
  brandId        Int?     @map("BRAND_ID")
  unitPrice      Decimal? @db.Decimal(10, 2) @map("UNIT_PRICE")
  sellingPrice   Decimal  @db.Decimal(10, 2) @map("SELLING_PRICE")
  quantity       Int      @map("QUANTITY")
  minThreshold   Int      @map("MIN_THRESHOLD")
  isFastMoving   Boolean  @default(false) @map("IS_FAST_MOVING")
  lastRestockedAt DateTime? @map("LAST_RESTOCKED_AT")
  sellByWeight   Boolean  @default(false) @map("SELL_BY_WEIGHT")
  sellByBox      Boolean  @default(false) @map("SELL_BY_BOX")
  boxQuantity    Int?     @map("BOX_QUANTITY")
  imageUrl       String?  @db.LongText @map("IMAGE_URL")
  isAvailable    Boolean  @default(true) @map("IS_AVAILABLE")
  createdAt      DateTime? @map("CREATED_AT")
  updatedAt      DateTime @default(now()) @updatedAt @map("UPDATED_AT")

  categoryRel    Category?         @relation(fields: [categoryId], references: [id])
  supplierRel    Supplier?         @relation(fields: [supplierId], references: [id])
  brandRel       Brand?            @relation(fields: [brandId], references: [id])
  transactionItems TransactionItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([brandId])
  @@map("products")
}

/// Transaction headers (one per receipt)
model Transaction {
  id                     Int               @id @default(autoincrement()) @map("TRANSACTION_ID")
  receiptNumber          Int               @map("RECEIPT_NUMBER")
  salesInvoiceNumber     String?           @map("SALES_INVOICE_NUMBER")
  deliveryReceiptNumber  String?           @map("DELIVERY_RECEIPT_NUMBER")
  tin                    String?           @map("TIN")
  buyerName              String            @map("BUYER_NAME")
  buyerAddress           String?           @map("BUYER_ADDRESS")
  buyerContact           String?           @map("BUYER_CONTACT")
  sellerId               Int?              @map("SELLER_ID")
  sellerName             String?           @map("SELLER_NAME")
  transactionType        TransactionType   @map("TRANSACTION_TYPE")
  deliveryMethod         DeliveryMethod    @map("DELIVERY_METHOD")
  deliveryRef            String?           @map("DELIVERY_REF")
  deliveryNotes          String?           @map("DELIVERY_NOTES")
  delivererName          String?           @map("DELIVERER_NAME")
  transactionStatus      TransactionStatus @default(Ongoing) @map("TRANSACTION_STATUS")
  transactionDate        DateTime          @map("TRANSACTION_DATE")
  grandTotal             Decimal?          @db.Decimal(10, 2) @map("GRAND_TOTAL")
  paymentMethod          String?           @map("PAYMENT_METHOD")
  isCredit               Boolean           @default(false) @map("IS_CREDIT")
  creditDueDate          DateTime?         @map("CREDIT_DUE_DATE")
  creditPaidAt           DateTime?         @map("CREDIT_PAID_AT")
  creditAmountPaid       Decimal           @default(0) @db.Decimal(10, 2) @map("CREDIT_AMOUNT_PAID")
  creditPenaltyFee       Decimal           @default(0) @db.Decimal(10, 2) @map("CREDIT_PENALTY_FEE")
  creditLastPaymentDate  DateTime?         @map("CREDIT_LAST_PAYMENT_DATE")
  chequeNumber           String?           @map("CHEQUE_NUMBER")
  chequeBankName         String?           @map("CHEQUE_BANK_NAME")
  chequeDate             DateTime?         @map("CHEQUE_DATE")
  chequePayeeName        String?           @map("CHEQUE_PAYEE_NAME")
  isReturned             Boolean           @default(false) @map("IS_RETURNED")
  returnForReceiptNumber Int?              @map("RETURN_FOR_RECEIPT_NUMBER")
  discountType           String?           @db.VarChar(20) @map("DISCOUNT_TYPE")
  discountValue          Decimal?          @db.Decimal(10, 2) @map("DISCOUNT_VALUE")
  buyerId                Int?              @map("BUYER_ID")
  createdAt              DateTime?         @map("CREATED_AT")
  updatedAt              DateTime          @default(now()) @updatedAt @map("UPDATED_AT")

  seller User?              @relation(fields: [sellerId], references: [id])
  buyer  Buyer?             @relation(fields: [buyerId], references: [id])
  items  TransactionItem[]

  @@index([sellerId])
  @@index([receiptNumber])
  @@index([transactionDate])
  @@map("transactions")
}

/// Line items within a transaction
model TransactionItem {
  id            Int      @id @default(autoincrement()) @map("ITEM_ID")
  transactionId Int?     @map("TRANSACTION_ID")
  productId     Int?     @map("PRODUCT_ID")
  productName   String?  @map("PRODUCT_NAME")
  quantity      Int?     @map("QUANTITY")
  unitPrice     Decimal? @db.Decimal(10, 2) @map("UNIT_PRICE")
  totalPrice    Decimal? @db.Decimal(10, 2) @map("TOTAL_PRICE")
  costPrice     Decimal? @db.Decimal(10, 2) @map("COST_PRICE")

  transaction Transaction? @relation(fields: [transactionId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

/// System-generated notifications (stock alerts, transaction reminders)
model Notification {
  id                 Int                 @id @default(autoincrement()) @map("NOTIFICATION_ID")
  systemNotification String              @map("SYSTEM_NOTIFICATIONS")
  message            String              @map("MESSAGE")
  createdAt          DateTime            @default(now()) @map("CREATED_AT")
  reads              NotificationRead[]

  @@map("notifications")
}

/// Tracks per-user read status for notifications
model NotificationRead {
  id             Int          @id @default(autoincrement())
  notificationId Int
  userId         Int
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

/// Rate limiting (auth attempts, API throttling)
model RateLimit {
  id        String   @id
  attempts  Int
  resetAt   DateTime

  @@map("rate_limits")
}

/// Customers / clients who purchase products
model Buyer {
  id           Int      @id @default(autoincrement()) @map("BUYER_ID")
  name         String   @map("BUYER_NAME")
  email        String?  @map("EMAIL")
  phone        String?  @map("PHONE")
  address      String?  @map("ADDRESS")
  tin          String?  @map("TIN")
  notes        String?  @map("NOTES")
  imageUrl     String?  @db.LongText @map("IMAGE_URL")
  totalOrders  Int      @default(0) @map("TOTAL_ORDERS")
  totalSpent   Decimal  @default(0) @db.Decimal(10, 2) @map("TOTAL_SPENT")
  creditBalance Decimal @default(0) @db.Decimal(10, 2) @map("CREDIT_BALANCE")
  sellerId     Int?     @map("SELLER_ID")
  createdAt    DateTime @default(now()) @map("CREATED_AT")
  updatedAt    DateTime @default(now()) @updatedAt @map("UPDATED_AT")

  seller       User?         @relation(fields: [sellerId], references: [id])
  transactions Transaction[]

  @@index([sellerId])
  @@map("buyers")
}

/// User-uploaded downloadable files
model CustomDownloadable {
  id          Int      @id @default(autoincrement()) @map("CUSTOM_DOWNLOADABLE_ID")
  name        String   @map("NAME")
  description String?  @map("DESCRIPTION")
  fileName    String   @map("FILE_NAME")
  fileData    String   @db.LongText @map("FILE_DATA")
  fileType    String   @map("FILE_TYPE")
  fileSize    Int      @map("FILE_SIZE")
  uploadedBy  Int?     @map("UPLOADED_BY")
  createdAt   DateTime @default(now()) @map("CREATED_AT")

  uploader User? @relation(fields: [uploadedBy], references: [id])

  @@map("custom_downloadables")
}

/// Full audit trail for all user actions
model AuditLog {
  id            Int      @id @default(autoincrement()) @map("LOG_ID")
  sellerId      Int?     @map("SELLER_ID")
  logTime       DateTime @default(now()) @map("LOG_TIME")
  successStatus Boolean  @default(true) @map("SUCCESS_STATUS")
  panel         String?  @map("PANEL")
  action        String?  @map("ACTION")
  details       String?  @map("DETAILS")

  seller User? @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([logTime])
  @@map("audit_log")
}

/// Queued low-stock alerts pending email delivery at noon/8pm PH
model LowStockAlert {
  id          Int      @id @default(autoincrement()) @map("ALERT_ID")
  productName String   @map("PRODUCT_NAME")
  quantity    Int      @map("QUANTITY")
  minThreshold Int     @map("MIN_THRESHOLD")
  sentAt      DateTime? @map("SENT_AT")
  createdAt   DateTime @default(now()) @map("CREATED_AT")

  @@index([sentAt])
  @@map("low_stock_alerts")
}
