# Prisma connection string (NeonDB PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full"

# Recommended for most uses
ANVILOS_DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full"

# For uses requiring a connection without pgbouncer
ANVILOS_DATABASE_URL_UNPOOLED=""

# Parameters for constructing your own connection string
ANVILOS_PGHOST=""
ANVILOS_PGHOST_UNPOOLED=""
ANVILOS_PGUSER=""
ANVILOS_PGDATABASE=""
ANVILOS_PGPASSWORD=""

